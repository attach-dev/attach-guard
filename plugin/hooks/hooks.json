{
  "description": "Intercepts package install commands and enforces supply-chain security policies",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/bootstrap.sh hook",
            "timeout": 30
          }
        ]
      }
    ]
  }
}
